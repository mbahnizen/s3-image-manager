# Default endpoint uses Kilat Storage. You can replace it with your own S3-compatible endpoint.
S3_ENDPOINT=https://s3-id-jkt-1.kilatstorage.id
S3_BUCKET=your_bucket_name
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=id-jkt-1
PUBLIC_URL_BASE=https://s3-id-jkt-1.kilatstorage.id/your_bucket_name/
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SESSION_LIFETIME_SECONDS=43200
SESSION_IDLE_TIMEOUT_SECONDS=7200
WORKSPACE_SYNC_THRESHOLD=20
WORKSPACE_JOB_STALE_MINUTES=15
